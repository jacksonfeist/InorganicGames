---
import { getCollection } from 'astro:content';
import CTAButton from './CTAButton.astro';
import PhoneFrame from './PhoneFrame.astro';

/**
 * §1 Hero. Pain first, then what we do, then one action.
 *
 * The failure mode this section exists to avoid: opening with "We're Inorganic
 * Games, an indie game studio…". Nobody buying playables cares who we are until
 * we've named their problem. See docs/homepage.md §1.
 *
 * HEADLINE is the working example from docs/homepage.md. Alternatives drafted
 * against docs/positioning.md, swap in one line:
 *   B. "Five days. That's how long your top creative has left."
 *   C. "You're not out of budget. You're out of creative."
 *   D. "Your creative dies in under a week. Then you feed the machine again."
 *
 * The "under a week" claim is sourced — effective creative lifespan in mature
 * markets is under ~5 days (Game Growth Advisor, May 2026). Don't swap in a
 * headline that asserts a number we can't source.
 */
const HEADLINE = 'Your best creative is already dead.';
const HEADLINE_SUB = 'Ad fatigue kills it in under a week.';

/**
 * The hero visual is a REAL demo build, click-to-play — the strongest possible
 * opening claim for a playable-ads studio is a playable, right here, above the
 * fold. Never a video: if it isn't tappable it isn't proof.
 *
 * Cloud Runner is the pick because its loop reads in one glance. If it's ever
 * removed, fall back to any embeddable demo rather than an empty frame.
 */
const HERO_DEMO_ID = 'chroma-sort';
const playables = await getCollection('playables');
const heroDemo =
  playables.find((p) => p.id === HERO_DEMO_ID && p.data.embedReady) ??
  playables.find((p) => p.data.kind !== 'shipped' && p.data.embedReady);
---

<section class="px-6 pt-20 pb-20 md:pt-28 md:pb-28">
  <div class="mx-auto grid max-w-6xl items-center gap-16 lg:grid-cols-[1.15fr_1fr]">
    <div>
      <h1 class="font-display text-5xl leading-[0.95] tracking-wide text-bone md:text-7xl">
        {HEADLINE}
        <span class="block text-muted">{HEADLINE_SUB}</span>
      </h1>

      <p class="mt-8 max-w-xl text-lg leading-relaxed text-muted">
        Inorganic builds playable ads engineered to convert: <span class="text-bone"
          >real gameplay, every network, fast iteration</span
        >.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-6">
        <CTAButton />
        <a href="#work" class="text-sm text-muted underline-offset-4 transition-colors hover:text-signal hover:underline">
          or play the demos ↓
        </a>
      </div>

      <p class="mt-10 max-w-xl border-l-2 border-ink-line pl-4 text-sm leading-relaxed text-muted">
        Creative lifespan in mature markets is under five days, with 84,000+ mobile advertisers
        bidding into the same auction every month.
      </p>
    </div>

    {
      heroDemo && (
        <figure class="flex flex-col items-center lg:items-end">
          <PhoneFrame class="w-full max-w-[280px]">
            <div class="relative h-full w-full" data-hero-playable>
              <iframe
                data-src={`/playables/${heroDemo.id}/index.html`}
                title={`Playable: ${heroDemo.data.targetGame}`}
                class="absolute inset-0 h-full w-full border-0 opacity-0 transition-opacity duration-300"
                loading="lazy"
                scrolling="no"
              />
              <button
                type="button"
                data-play
                class="absolute inset-0 flex flex-col items-center justify-center gap-3 bg-cover bg-center transition-colors hover:bg-ink/70"
                style={
                  heroDemo.data.poster
                    ? `background-image:linear-gradient(rgba(8,7,12,.55),rgba(8,7,12,.55)),url(${heroDemo.data.poster})`
                    : undefined
                }
              >
                <span class="flex h-14 w-14 items-center justify-center rounded-full bg-signal text-ink">
                  <svg viewBox="0 0 24 24" fill="currentColor" class="ml-1 h-6 w-6">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </span>
                <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-bone">
                  Tap to play
                </span>
              </button>
            </div>
          </PhoneFrame>
        </figure>
      )
    }
  </div>
</section>

<script>
  // Same click-to-play pattern as the gallery cards: hold the src in data-src
  // and only boot the ad when asked to.
  const wrap = document.querySelector<HTMLElement>('[data-hero-playable]');
  const button = wrap?.querySelector<HTMLButtonElement>('[data-play]');
  const frame = wrap?.querySelector<HTMLIFrameElement>('iframe');

  if (button && frame) {
    button.addEventListener('click', () => {
      const src = frame.dataset.src;
      if (!src) return;
      frame.src = src;
      frame.classList.replace('opacity-0', 'opacity-100');
      button.remove();
    });
  }
</script>
