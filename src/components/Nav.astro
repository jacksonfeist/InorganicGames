---
import CTAButton from './CTAButton.astro';

/**
 * Global nav: Demos · How it works · Past work · Why playables? · [Contact].
 * Labels match the section headings they scroll to — "Demos" is the live shelf
 * (#work), "Past work" is the shipped-titles strip (#studio).
 *
 * v1 is one scroll — the doc suggests merging Work into Home — so these are
 * anchors, not routes. Dead nav links to stub pages are worse than no pages.
 *
 * Nav renders on every page via Base.astro, so the homepage anchors are
 * absolute (`/#work`) rather than bare (`#work`) — a bare anchor from
 * /why-playables would just scroll nowhere on that page instead of returning
 * to the section on Home.
 */
const links = [
  { label: 'Demos', href: '/#work' },
  { label: 'How it works', href: '/#how-it-works' },
  { label: 'Past work', href: '/#studio' },
  { label: 'Why playables?', href: '/why-playables' },
];
---

<header class="sticky top-0 z-50 border-b border-ink-line bg-ink/85 backdrop-blur-sm">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="font-display text-2xl tracking-wider text-bone">
      INORGANIC<span class="text-signal">.</span>
    </a>

    <div class="flex items-center gap-8">
      <ul class="hidden items-center gap-8 md:flex">
        {
          links.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-muted transition-colors hover:text-bone">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
      <CTAButton label="Contact" class="px-4 py-2 text-xs" />
    </div>
  </nav>
</header>
