---
interface Props {
  label?: string;
  variant?: 'primary' | 'ghost';
  class?: string;
  /** Override the destination (e.g. "#contact"). Defaults to the contact page. */
  href?: string;
}

const { label = 'Get in touch', variant = 'primary', class: klass = '', href: hrefOverride } = Astro.props;

/**
 * One primary CTA everywhere: get in touch by email. Every button routes to
 * the contact page rather than firing a mailto straight from a nav bar or
 * hero, so the click always lands somewhere with context and a real ask.
 */
const href = hrefOverride ?? '/contact';

const base =
  'inline-flex items-center justify-center px-6 py-3 text-sm font-semibold tracking-wide transition-colors duration-150';
const styles =
  variant === 'primary'
    ? 'bg-signal text-ink hover:bg-signal-dim'
    : 'border border-ink-line text-bone hover:border-signal hover:text-signal';
---

<a href={href} class={`${base} ${styles} ${klass}`}>
  {label}
</a>
