---
interface Props {
  current: 'docs' | 'security' | 'privacy' | 'terms' | 'support';
}

const { current } = Astro.props;

const links = [
  { key: 'docs', label: 'Docs', href: '/secure-fields/docs' },
  { key: 'security', label: 'Security', href: '/secure-fields/security' },
  { key: 'privacy', label: 'Privacy', href: '/secure-fields/privacy' },
  { key: 'terms', label: 'Terms', href: '/secure-fields/terms' },
  { key: 'support', label: 'Support', href: '/secure-fields/support' },
] as const;
---

<div class="rule px-6 py-6">
  <div class="mx-auto flex max-w-3xl flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-signal">
      Secure Fields <span class="text-muted normal-case tracking-normal">· a Jira Cloud app by Inorganic Games LLC</span>
    </p>
    <nav class="flex flex-wrap gap-x-5 gap-y-1 font-mono text-xs">
      {
        links.map((link) => (
          <a
            href={link.href}
            class={`transition-colors ${current === link.key ? 'text-signal' : 'text-muted hover:text-bone'}`}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</div>
