---
import { getCollection } from 'astro:content';
import Section from './Section.astro';
import PlayableCard from './PlayableCard.astro';
import CTAButton from './CTAButton.astro';

/**
 * §2 — the centerpiece. This section IS the proof shelf, and the thing that
 * separates a studio from a slideshow.
 *
 * Demo and concept builds only. Shipped titles (the TikTok Minis) are a
 * different claim — "we publish games" rather than "here is the ad we'd build
 * you" — so they live in the Past work section (StudioStrip), not on this
 * shelf.
 *
 * Do not fill this with videos, GIFs, or stock demos: if it isn't tappable it
 * isn't proof, and the buyer can tell instantly.
 */
const playables = (await getCollection('playables'))
  .filter((p) => p.data.kind !== 'shipped')
  .sort((a, b) => a.data.order - b.data.order);

// Concept builds are the spec-led outreach asset and the thing a buyer screening
// for *their* genre is actually looking for. Studio demos and shipped titles
// prove we can build; they don't prove we've built for a game like theirs.
const hasConceptBuilds = playables.some((p) => p.data.kind === 'concept');
---

<Section
  id="work"
  eyebrow="Live demos"
  title="Play the work. Right now, in this browser."
  lede="Real, tappable builds, not videos of builds. Each one reports its own size and network requests while you play."
>
  {
    playables.length > 0 ? (
      <>
        <div class="grid gap-x-8 gap-y-16 sm:grid-cols-2 xl:grid-cols-4">
          {playables.map((entry) => (
            <PlayableCard entry={entry} />
          ))}
        </div>

        <div class="mt-16 flex flex-col items-start gap-6 border-l-2 border-signal/40 pl-5 sm:flex-row sm:items-center sm:justify-between sm:gap-10">
          {!hasConceptBuilds ? (
            /* Demo builds are in the grid but no concept builds are. Say so —
               they are not the same claim, and a buyer screening for genre proof
               in *their* game deserves to know which one they're looking at. */
            <p class="max-w-xl text-sm leading-relaxed text-muted">
              <span class="text-bone">Next on this shelf: your game.</span> We build one playable
              free. Send it and see what comes back.
            </p>
          ) : (
            <p class="max-w-xl text-sm leading-relaxed text-muted">
              <span class="text-bone">Not your genre yet?</span> We build one playable free. Send
              your game and see what comes back.
            </p>
          )}
          <CTAButton label="Get a free build" variant="ghost" href="#contact" class="shrink-0" />
        </div>
      </>
    ) : (
      <div class="border border-dashed border-ink-line bg-ink-raised px-8 py-20 text-center">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-signal">Concept builds in production</p>
        <p class="mx-auto mt-6 max-w-lg text-lg leading-relaxed text-muted">
          Live, tappable demos land here: each a concept build for a real, named game.
        </p>
        <p class="mx-auto mt-4 max-w-lg text-lg leading-relaxed text-bone">
          Want yours built first? We'll build one for your game, free.
        </p>
        <CTAButton label="Get in touch" class="mt-8" />
      </div>
    )
  }
</Section>
