---
interface Props {
  class?: string;
}

const { class: klass = '' } = Astro.props;

// A phone shell. Whatever goes inside must be genuinely tappable, never a video.
// Kept as a frontmatter comment, not an HTML one: HTML comments here ship to the
// browser and appear once per card in the page source.
---

<div
  class={`relative aspect-[9/19] w-full overflow-hidden rounded-[2rem] border border-ink-line bg-ink-raised shadow-2xl ${klass}`}
>
  <slot />
</div>
