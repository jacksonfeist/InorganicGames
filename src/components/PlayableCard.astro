---
import type { CollectionEntry } from 'astro:content';
import PhoneFrame from './PhoneFrame.astro';

interface Props {
  entry: CollectionEntry<'playables'>;
  /**
   * Build stats: the size/requests/fps line that updates live while the ad
   * runs. On for the demo shelf, where the engineering envelope is the claim;
   * off for past work, where the card is proof of craft, not a spec sheet.
   */
  stats?: boolean;
  /** Extra context after the honesty label, e.g. "TikTok Mini Game". */
  sublabel?: string;
}

const { entry, stats = true, sublabel } = Astro.props;
const { targetGame, genre, mechanic, buildSizeKB, kind, embedReady, poster } = entry.data;

/**
 * The label is the honesty mechanism, so it is derived from `kind` and never
 * hand-written per card.
 *
 *   concept → "Concept build for X". Someone else's named game. Not a campaign,
 *             and no results are ever attached to it.
 *   demo    → "Studio demo build". Our own IP, built to prove an archetype. It
 *             has not shipped and has not run on a network, so it claims neither.
 *   shipped → an actual title we published.
 *
 * See docs/playables.md §Honesty guardrails.
 */
const LABELS = {
  concept: `Concept build for ${targetGame}`,
  demo: 'Studio demo build',
  shipped: 'Shipped title',
} as const;
const label = LABELS[kind];

const embedSrc = `/playables/${entry.id}/index.html`;

/**
 * These builds are 100–140KB, which is the whole point — roughly 2% of the 5MB
 * network cap. Dividing everything by 1000 and stamping "MB" rendered that as
 * "0.1MB", which reads as a rounding error rather than the claim it is.
 */
const fmtSize = (kb: number) => (kb >= 1000 ? `${(kb / 1000).toFixed(1)} MB` : `${kb} KB`);
---

<article class="group">
  {/* Everything is constrained to the phone's width so a shelf of cards reads
      as aligned columns rather than phones floating over wider text blocks. */}
  <div class="mx-auto w-full max-w-[280px]">
    <PhoneFrame>
      {
        embedReady ? (
          <div class="relative h-full w-full" data-playable>
            {/*
              Click-to-play: the iframe src is held in data-src and only assigned on
              click. Booting six playables at once on page load would make a page
              about ad performance slow, which is an argument against us.
            */}
            <iframe
              data-src={embedSrc}
              title={`Playable: ${targetGame}`}
              class="absolute inset-0 h-full w-full border-0 opacity-0 transition-opacity duration-300"
              loading="lazy"
              scrolling="no"
            />
            <button
              type="button"
              data-play
              class="absolute inset-0 flex flex-col items-center justify-center gap-3 bg-cover bg-center transition-colors hover:bg-ink/70"
              style={poster ? `background-image:linear-gradient(rgba(8,7,12,.55),rgba(8,7,12,.55)),url(${poster})` : undefined}
            >
              <span class="flex h-14 w-14 items-center justify-center rounded-full bg-signal text-ink">
                <svg viewBox="0 0 24 24" fill="currentColor" class="ml-1 h-6 w-6">
                  <path d="M8 5v14l11-7z" />
                </svg>
              </span>
              <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-bone">Tap to play</span>
            </button>
          </div>
        ) : (
          /* No build in public/playables/<id>/ yet. An honest empty frame beats a
             dead iframe, and beats a video pretending to be a playable. */
          <div class="flex h-full w-full flex-col items-center justify-center gap-3 border-2 border-dashed border-ink-line p-6 text-center">
            <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-muted">
              Build not embedded yet
            </span>
            <span class="text-xs leading-relaxed text-ink-line">
              Drop it in public/playables/{entry.id}/
            </span>
          </div>
        )
      }
    </PhoneFrame>

    {
      stats && embedReady && (
        /*
          The stats line. Size and requests are build facts and true before anyone
          taps, so they render from frontmatter immediately; the running ad then
          overwrites them with its own measurement (docs/gallery-embed.md in the
          playable-ads repo). The demo is not just claiming zero requests — it is
          reporting them while you play it.
        */
        <div class="mt-3" data-telemetry>
          <p class="font-mono text-[9px] uppercase tracking-[0.2em] text-ink-line">
            Measured live from the frame
          </p>
          <p class="mt-1 font-mono text-[11px] text-muted">
            <span data-badge-bytes>{buildSizeKB ? fmtSize(buildSizeKB) : '—'}</span>
            <span class="text-ink-line"> · </span>
            <span data-badge-requests>0 requests</span>
            <span class="text-ink-line"> · </span>
            <span data-badge-fps class="text-ink-line">idle</span>
          </p>
        </div>
      )
    }

    <div class="mt-5">
      <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-signal">
        {label}{sublabel && <span class="text-muted"> · {sublabel}</span>}
      </p>
      <h3 class="mt-2 font-display text-2xl tracking-wide text-bone">{targetGame}</h3>
      <p class="mt-2 text-sm leading-relaxed text-muted">{mechanic}</p>
      {
        stats && (
          <p class="mt-3 font-mono text-[11px] text-muted">{genre}</p>
        )
      }
    </div>
  </div>
</article>

<script>
  interface AdMeta {
    type: 'inorganic_meta';
    meta: { bytes: number; requests: number; fps: number };
  }

  document.querySelectorAll<HTMLElement>('[data-playable]').forEach((wrap) => {
    const button = wrap.querySelector<HTMLButtonElement>('[data-play]');
    const frame = wrap.querySelector<HTMLIFrameElement>('iframe');
    if (!button || !frame) return;

    // The stats line is the phone frame's sibling inside the same card. Cards
    // rendered with stats off have no panel, hence the null guards throughout.
    const card = wrap.closest('article');
    const badgeBytes = card?.querySelector<HTMLElement>('[data-badge-bytes]');
    const badgeRequests = card?.querySelector<HTMLElement>('[data-badge-requests]');
    const badgeFps = card?.querySelector<HTMLElement>('[data-badge-fps]');

    button.addEventListener('click', () => {
      const src = frame.dataset.src;
      if (!src) return;
      frame.src = src;
      frame.classList.replace('opacity-0', 'opacity-100');
      button.remove();
    });

    // Every playable on the page posts to this same window, so filtering by
    // source is what keeps the cards from writing into each other's badges.
    addEventListener('message', (event: MessageEvent) => {
      if (event.source !== frame.contentWindow) return;

      const data = event.data as AdMeta | null;
      if (!data || typeof data !== 'object' || data.type !== 'inorganic_meta' || !data.meta) return;

      const { bytes, requests, fps } = data.meta;
      if (badgeBytes && typeof bytes === 'number') {
        badgeBytes.textContent = `${Math.round(bytes / 1024)} KB`;
      }
      if (badgeRequests && typeof requests === 'number') {
        badgeRequests.textContent = `${requests} request${requests === 1 ? '' : 's'}`;
        // The zero-network guarantee is the claim; make a broken one obvious
        // rather than letting it slide past in the same muted grey.
        badgeRequests.classList.toggle('text-signal', requests === 0);
        badgeRequests.classList.toggle('text-red-400', requests !== 0);
      }
      if (badgeFps && typeof fps === 'number') {
        badgeFps.textContent = `${Math.round(fps)} fps`;
        badgeFps.classList.remove('text-ink-line');
      }
    });
  });
</script>
