---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../config/site';

interface Props {
  title: string;
  description: string;
  /** 'website' for standalone pages, 'article' if that's ever needed. */
  type?: 'website' | 'article';
  /**
   * Extra JSON-LD object(s) for this page only (e.g. FAQPage). The sitewide
   * Organization/WebSite graph below is added automatically — don't repeat it
   * here.
   */
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, type = 'website', structuredData } = Astro.props;

// Astro.site is the configured origin (https://inorganicgames.com); this is
// the actual per-page URL. Previously every page declared the homepage as
// canonical, which tells search engines the subpages are duplicates.
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL('/logo.png', Astro.site);

const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.name,
  url: String(Astro.site),
  logo: ogImageURL.toString(),
  email: SITE.email,
  description: 'A game studio that builds playable ads engineered to convert for mobile UA teams.',
};

const pageStructuredData = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:image" content={ogImageURL} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="icon" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(organizationLd)} />
    {
      pageStructuredData.map((entry) => (
        <script type="application/ld+json" set:html={JSON.stringify(entry)} />
      ))
    }
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
