---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import PlayableGallery from '../components/PlayableGallery.astro';
import ProofBar from '../components/ProofBar.astro';
import Alternatives from '../components/Alternatives.astro';
import HowItWorks from '../components/HowItWorks.astro';
import PlumbingStrip from '../components/PlumbingStrip.astro';
import CaseStudyTeaser from '../components/CaseStudyTeaser.astro';
import StudioStrip from '../components/StudioStrip.astro';
import FinalCTA from '../components/FinalCTA.astro';

/**
 * The nine sections of docs/homepage.md, in scroll order. Order is load-bearing:
 * pain → proof → legitimacy. Don't move the studio strip up — nobody buying
 * playables cares who we are until we've named their problem.
 *
 * The gallery carries demo/concept builds only; the shipped TikTok Minis live
 * in StudioStrip (§8, "Past work") so the ad demos and the published games stay
 * two distinct claims.
 */
---

<Base
  title="Inorganic Games: Playable Ads Built by a Real Game Studio"
  description="A real game studio that builds playable ads engineered to convert. Real gameplay, every network, fast iteration. Play the live demos in your browser."
>
  <Hero />
  <!-- 2 — the centerpiece: the live, tappable demo shelf. -->
  <PlayableGallery />
  <ProofBar />
  <Alternatives />
  <HowItWorks />
  <PlumbingStrip />
  <!-- 7 — renders nothing until there's a real client result. Gated, not faked. -->
  <CaseStudyTeaser />
  <StudioStrip />
  <FinalCTA />
</Base>
