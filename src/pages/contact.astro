---
import Base from '../layouts/Base.astro';
import { SITE, resolved } from '../config/site';

/**
 * The destination for every "Get in touch" CTA on the site. Email is the
 * main action; there is no direct-booking flow yet, so this page is where
 * that conversation actually starts. See CTAButton.astro.
 */
const responseTime = resolved(SITE.responseTime);

const title = 'Contact | Inorganic Games';
const description = `Get in touch with Inorganic Games about a playable ad build. Email ${SITE.email}.`;
---

<Base title={title} description={description}>
  <section class="px-6 pt-20 pb-20 md:pt-28 md:pb-28">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-4 font-mono text-xs uppercase tracking-[0.2em] text-signal">Contact</p>
      <h1 class="font-display text-5xl leading-[0.95] tracking-wide text-bone md:text-6xl">
        Tell us about your game.
      </h1>
      <p class="mx-auto mt-8 max-w-xl text-lg leading-relaxed text-muted">
        Email is the fastest way to reach us. Send the game, the geo, and what you're running now,
        and we'll take it from there.
      </p>

      <a
        href={`mailto:${SITE.email}`}
        class="mt-10 inline-flex items-center justify-center bg-signal px-8 py-4 text-lg font-semibold tracking-wide text-ink transition-colors hover:bg-signal-dim"
      >
        {SITE.email}
      </a>

      {
        responseTime && (
          <p class="mt-6 text-sm text-muted">
            We reply <span class="text-bone">{responseTime}</span>.
          </p>
        )
      }

      <p class="mt-16 text-sm text-muted">
        Want to see something first?{' '}
        <a href="/#work" class="text-signal underline-offset-4 hover:underline">Play the live demos</a>.
      </p>
    </div>
  </section>
</Base>
