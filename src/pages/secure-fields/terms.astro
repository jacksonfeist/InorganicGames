const title = 'End User Terms | Secure Fields';
const description = 'End User Terms for Secure Fields: Provider-Specific Terms plus the Bonterms Standard End User Agreement (Version 1.0).';
---

<Base title={title} description={description}>
  <SecureFieldsCrumbs current="terms" />

  <article class="mx-auto max-w-3xl px-6 py-16 md:py-20">
    <p class="mb-3 font-mono text-xs uppercase tracking-[0.2em] text-signal">Legal</p>
    <h1 class="font-display text-4xl tracking-wide text-bone md:text-5xl">End User Terms</h1>
    <p class="mt-3 text-sm text-muted">Inorganic Games LLC &mdash; Secure Fields<br />Last updated: July 16, 2026</p>

    <div class="mt-10 space-y-10 leading-relaxed text-muted">
      <section>
        <p class="mt-3">
          These End User Terms ("Terms") govern use of Secure Fields (the "Product"), a Jira Cloud app
          published by Inorganic Games LLC ("Provider," "we," "us," or "our") through the Atlassian
          Marketplace. The Terms consist of two parts:
        </p>
        <ol class="mt-3 list-decimal space-y-2 pl-5">
          <li>
            <strong class="text-bone">Part A &mdash; Provider-Specific Terms</strong>, below, which fill in
            and, where noted, override specific sections of&hellip;
