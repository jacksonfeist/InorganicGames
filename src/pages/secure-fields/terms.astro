          <div>
            <dt class="font-mono text-xs uppercase tracking-wide text-signal">Provider</dt>
            <dd class="mt-1">Inorganic Games LLC</dd>
          </div>
          <div>
            <dt class="font-mono text-xs uppercase tracking-wide text-signal">Product</dt>
            <dd class="mt-1">Secure Fields (a "Cloud Service" as defined in the Standard Agreement)</dd>
          </div>
          <div>
            <dt class="font-mono text-xs uppercase tracking-wide text-signal">Notice address (Section 19.3)</dt>
            <dd class="mt-1">
              <a href="mailto:support@inorganicgames.com" class="text-signal underline underline-offset-2 hover:text-signal-dim">support@inorganicgames.com</a>
            </dd>
          </div>
          <div>
            <dt class="font-mono text-xs uppercase tracking-wide text-signal">Governing Law and Courts (Section 19.2)</dt>
            <dd class="mt-1">
